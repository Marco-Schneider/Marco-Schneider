---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);
---

<section class="section">
    <p class="section-label">Latest posts</p>
    <div class="posts">
        {
            posts.map((post) => (
                <a href={`/blog/${post.id}`} class="post">
                    <div class="post-left">
                        <span class="cat">{post.data.category}</span>
                        <span class="title">{post.data.title}</span>
                    </div>
                    <span class="date">
                        {post.data.pubDate.toLocaleDateString('en-US', {
                            month: 'short',
                            year: 'numeric',
                        })}
                    </span>
                </a>
            ))
        }
    </div>
    <a href="/blog" class="all-posts">All posts →</a>
</section>

<style>
    .section {
        padding: 40px 0;
        margin: 20px 0;
    }
    .section-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent-main);
        margin-bottom: 24px;
    }
    .posts {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .post {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 20px 24px;
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
        text-decoration: none;
        color: inherit;
    }
    .post:hover {
        transform: translateY(-2px);
        border-color: var(--accent-main);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4), 0 0 10px var(--accent-glow);
    }
    .post:hover .title {
        color: var(--accent-main);
    }
    .post-left {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .cat {
        display: inline-block;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        background: rgba(255, 255, 255, 0.05);
        color: var(--accent-secondary);
        padding: 4px 10px;
        border-radius: 99px;
        border: 1px solid var(--border-glass);
        width: max-content;
    }
    .title {
        font-size: 16px;
        font-weight: 600;
        color: var(--text-primary);
        transition: color 0.2s ease;
    }
    .date {
        font-size: 13px;
        color: var(--text-muted);
        white-space: nowrap;
        padding-top: 2px;
    }
    .all-posts {
        display: inline-block;
        margin-top: 24px;
        font-size: 14px;
        color: var(--accent-main);
        font-weight: 600;
        transition: color 0.2s ease, text-shadow 0.2s ease;
    }
    .all-posts:hover {
        color: var(--accent-secondary);
        text-shadow: 0 0 8px var(--accent-glow);
    }
</style>
