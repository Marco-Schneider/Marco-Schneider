---
import { SITE_TITLE } from '../consts';
---

<nav class="nav">
    <div class="site-title-container">
        <img src="/Marco-Schneider/icons/terminal.png" alt="Terminal Icon" width="24px" id="terminal-icon" style="display: block;"/>
        <a href="/Marco-Schneider/" class="nav-logo">{SITE_TITLE}</a> 
    </div>
    <div class="nav-right">
        <button class="mobile-menu-btn" aria-label="Toggle Menu" aria-expanded="false">
            <svg class="hamburger-icon" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
        <ul class="nav-links">
            <li><a href="/Marco-Schneider/#projects">Projects</a></li>
            <li><a href="/Marco-Schneider/blog">Blog</a></li>
            <li><a href="/Marco-Schneider/about">About</a></li>
            <!-- <li><a href="/#contact">Contact</a></li> -->
        </ul>
    </div>
</nav>

<script>
    const setupMobileMenu = () => {
        const btn = document.querySelector('.mobile-menu-btn');
        const menu = document.querySelector('.nav-links');
        
        if (btn && menu) {
            btn.addEventListener('click', () => {
                const expanded = btn.getAttribute('aria-expanded') === 'true';
                btn.setAttribute('aria-expanded', String(!expanded));
                menu.classList.toggle('open');
            });

            menu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    btn.setAttribute('aria-expanded', 'false');
                    menu.classList.remove('open');
                });
            });
        }
    };
    
    // Run on initial load
    setupMobileMenu();
    
    // Run on ViewTransitions navigation if applicable
    document.addEventListener('astro:after-swap', setupMobileMenu);
</script>

<style>
    .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 24px;
        margin: 20px 0;
        position: sticky;
        top: 20px;
        z-index: 100;
        background: var(--bg-glass);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border-glass);
        border-radius: 16px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
    }
    .nav-logo {
        font-size: 15px;
        font-weight: 500;
    }
    .nav-logo:hover {
        color: var(--accent-main);
        text-shadow: 0 0 8px var(--accent-glow);
    }
    .nav-right {
        display: flex;
        align-items: center;
        gap: 20px;
    }
    .nav-links {
        display: flex;
        gap: 24px;
        list-style: none;
        font-size: 13px;
        color: var(--text-secondary);
        margin: 0;
        padding: 0;
    }
    .nav-links a {
        text-decoration: none;
        color: inherit;
        transition: color 0.2s ease, text-shadow 0.2s ease;
    }
    .nav-links a:hover {
        color: var(--accent-main);
        text-shadow: 0 0 8px var(--accent-glow);
    }
    .site-title-container {
        display: flex !important; 
        justify-content: center; 
        align-items: center; 
        height: 24px; 
        gap: 8px
    }
    #terminal-icon {
        filter: brightness(0) invert(1);
    }
    .mobile-menu-btn {
        background: transparent;
        border: none;
        color: var(--text-secondary);
        cursor: pointer;
        padding: 4px;
        z-index: 101;
        transition: color 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .mobile-menu-btn:hover {
        color: var(--accent-main);
    }

    /* Hide the hamburger button on desktop screens */
    @media (min-width: 769px) {
        .mobile-menu-btn {
            display: none !important;
        }
    }

    /* Show hamburger and modify nav-links on mobile */
    @media (max-width: 768px) {
        .nav-links {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            margin-top: 10px;
            flex-direction: column;
            gap: 0;
            background: var(--bg-deep);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.8);
            padding: 16px 0;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.3s ease;
        }
        .nav-links.open {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
        .nav-links li {
            width: 100%;
            text-align: center;
        }
        .nav-links a {
            display: block;
            padding: 16px 24px;
            font-size: 16px;
        }
    }
</style>
