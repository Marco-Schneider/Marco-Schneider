---
interface Project {
    name: string;
    desc: string;
    tags: string[];
    url: string;
}

let projects: Project[] = [];

try {
    const profileRes = await fetch('https://github.com/Marco-Schneider');
    const profileHtml = await profileRes.text();
    
    const pinnedRepos: string[] = [];
    const repoRegex = /<span class="repo">([^<]+)<\/span>/g;
    let match: RegExpExecArray | null;
    
    while ((match = repoRegex.exec(profileHtml)) !== null) {
        pinnedRepos.push(match[1]);
    }
    
    const fetchedProjects = await Promise.all(
        pinnedRepos.map(async (repoName: string): Promise<Project | null> => {
            const repoRes = await fetch(`https://api.github.com/repos/Marco-Schneider/${repoName}`);
            if (!repoRes.ok) return null;
            const repoData = await repoRes.json();
            return {
                name: repoData.name,
                desc: repoData.description,
                tags: repoData.topics && repoData.topics.length > 0 
                    ? repoData.topics 
                    : (repoData.language ? [repoData.language] : []),
                url: repoData.html_url,
            };
        })
    );
    projects = fetchedProjects.filter((project): project is Project => project !== null);
} catch (error) {
    console.error('Failed to fetch pinned projects:', error);
}
---

<section id="projects" class="section">
    <p class="section-label">Selected projects</p>
    <div class="grid">
        {
            projects.map((p) => (
                <a href={p.url} class="card glass-panel">
                    <h3>{p.name}</h3>
                    <p>{p.desc}</p>
                    <div class="tags">
                        {p.tags.map((t) => (
                            <span class="tag">{t}</span>
                        ))}
                    </div>
                </a>
            ))
        }
    </div>
</section>

<style>
    .section {
        padding: 40px 0;
        margin: 20px 0;
    }
    .section-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent-main);
        margin-bottom: 24px;
    }
    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    @media (max-width: 600px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
    .card {
        display: block;
        padding: 24px;
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
        text-decoration: none;
        color: inherit;
    }
    .card:hover {
        transform: translateY(-4px);
        border-color: var(--accent-main);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.6), 0 0 15px var(--accent-glow);
    }
    .card h3 {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-primary);
    }
    .card p {
        font-size: 14px;
        color: var(--text-secondary);
        line-height: 1.6;
        margin-bottom: 16px;
    }
    .tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .tag {
        font-size: 11px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-glass);
        padding: 4px 10px;
        border-radius: 99px;
        color: var(--accent-secondary);
        font-weight: 500;
    }
</style>
