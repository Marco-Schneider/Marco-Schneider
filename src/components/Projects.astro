---
const projects = [
    {
        name: 'Enterprise CI/CD Automation',
        desc: 'Automated deployment pipelines for .NET and Angular microservices, reducing release time by 40%.',
        tags: ['Azure DevOps', '.NET', 'Angular'],
        url: '#',
    },
    {
        name: 'Autonomous Rover System',
        desc: 'Embedded control systems for a university robotics competition, featuring real-time sensor processing.',
        tags: ['C++', 'ROS', 'Embedded Systems'],
        url: '#',
    },
    {
        name: 'Scalable Inventory Sync',
        desc: 'High-performance API built with C# and SQL Server to handle millions of daily SKU updates.',
        tags: ['C#', 'SQL Server', 'Azure'],
        url: '#',
    },
    {
        name: 'Developer Tooling Hub',
        desc: 'Internal dashboard to manage technical debt and track agile team metrics across repositories.',
        tags: ['Angular', 'TypeScript', 'GitHub API'],
        url: '#',
    },
];
---

<section id="projects" class="section">
    <p class="section-label">Selected projects</p>
    <div class="grid">
        {
            projects.map((p) => (
                <a href={p.url} class="card glass-panel">
                    <h3>{p.name}</h3>
                    <p>{p.desc}</p>
                    <div class="tags">
                        {p.tags.map((t) => (
                            <span class="tag">{t}</span>
                        ))}
                    </div>
                </a>
            ))
        }
    </div>
</section>

<style>
    .section {
        padding: 40px 0;
        margin: 20px 0;
    }
    .section-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent-main);
        margin-bottom: 24px;
    }
    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    @media (max-width: 600px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
    .card {
        display: block;
        padding: 24px;
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
        text-decoration: none;
        color: inherit;
    }
    .card:hover {
        transform: translateY(-4px);
        border-color: var(--accent-main);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.6), 0 0 15px var(--accent-glow);
    }
    .card h3 {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-primary);
    }
    .card p {
        font-size: 14px;
        color: var(--text-secondary);
        line-height: 1.6;
        margin-bottom: 16px;
    }
    .tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .tag {
        font-size: 11px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-glass);
        padding: 4px 10px;
        border-radius: 99px;
        color: var(--accent-secondary);
        font-weight: 500;
    }
</style>
