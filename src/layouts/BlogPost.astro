---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, category, heroImage } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
    <article class="post">
        {heroImage && <Image class="post-hero" src={heroImage} alt={title} />}
        <header class="post-header">
            <span class="post-cat">{category}</span>
            <h1>{title}</h1>
            <time>{formattedDate}</time>
        </header>
        <div class="post-body">
            <slot />
        </div>
    </article>
</BaseLayout>

<style>
    .post {
        padding: 48px 0;
    }
    .post-hero {
        width: 100%;
        height: auto;
        max-height: 450px;
        object-fit: cover;
        border-radius: 12px;
        margin-bottom: 32px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
    }
    .post-header {
        border-bottom: 0.5px solid var(--border-glass);
        padding-bottom: 24px;
        margin-bottom: 32px;
    }
    .post-cat {
        display: inline-block;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        background: rgba(255, 255, 255, 0.05);
        color: var(--accent-secondary);
        padding: 4px 10px;
        border-radius: 99px;
        border: 1px solid var(--border-glass);
        margin-bottom: 12px;
    }
    .post-header h1 {
        font-size: 32px;
        font-weight: 500;
        line-height: 1.2;
        margin-bottom: 10px;
    }
    .post-header time {
        font-size: 13px;
        color: var(--text-muted);
    }
    .post-body {
        font-size: 16px;
        line-height: 1.8;
    }
    .post-body :global(h2) {
        font-size: 22px;
        font-weight: 500;
        margin: 2rem 0 0.75rem;
    }
    .post-body :global(h3) {
        font-size: 18px;
        font-weight: 500;
        margin: 1.5rem 0 0.5rem;
    }
    .post-body :global(p) {
        margin-bottom: 1.25rem;
    }
    .post-body :global(pre) {
        background: var(--bg-surface);
        border: 0.5px solid var(--border);
        border-radius: 8px;
        padding: 1rem;
        overflow-x: auto;
        margin-bottom: 1.25rem;
    }
    .post-body :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 12px;
        margin: 32px auto;
        display: block;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
        border: 1px solid var(--border-glass);
    }
    .post-body :global(code) {
        font-family: monospace;
        font-size: 14px;
    }
    .post-body :global(a) {
        color: var(--accent-main);
        text-decoration: underline;
    }
</style>
